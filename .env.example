# CC Orchestrator Environment Variables
# Copy to .env and fill in actual values

# === Auth (choose one) ===
# Option A: API key
# ANTHROPIC_API_KEY=
# Option B: Claude Max OAuth — set HOST paths to your ~/.claude/ directory and ~/.claude.json
HOST_CLAUDE_DIR=/home/YOUR_USERNAME/.claude
HOST_CLAUDE_JSON=/home/YOUR_USERNAME/.claude.json
HOST_USER_UID=1000

# === Optional (needed for voice input) ===
OPENAI_API_KEY=

# === Worker Config ===
MAX_CONCURRENT_WORKERS=5
WORKER_CPU_LIMIT=2
WORKER_MEM_LIMIT=4g
TASK_TIMEOUT_SECONDS=600
MAX_RETRIES=3
CC_MODEL=claude-sonnet-4-5-20250514

# === Plan Mode ===
SKIP_PLAN_FOR_P2=true
# AUTO_APPROVE_TIMEOUT=300  # Uncomment to enable auto-approve (seconds)

# === Backup ===
BACKUP_INTERVAL_HOURS=1
MAX_BACKUPS=48

# === Server Ports ===
PORT=8080
FRONTEND_PORT=3000
