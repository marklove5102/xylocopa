# AgentHive Environment Variables
# Copy to .env and fill in actual values

# === Host Paths (REQUIRED — must be absolute paths) ===
# Projects directory — where all project code lives on the host
HOST_PROJECTS_DIR=/home/YOUR_USERNAME/agenthive-projects

# === Claude Credentials (optional — for token usage monitoring) ===
# Path to Claude CLI credentials file (default: ~/.claude/.credentials.json)
# CLAUDE_CREDENTIALS_PATH=/home/YOUR_USERNAME/.claude/.credentials.json

# === Optional (needed for voice input) ===
OPENAI_API_KEY=

# === Worker Config ===
MAX_CONCURRENT_WORKERS=5
MAX_IDLE_AGENTS=20
TASK_TIMEOUT_SECONDS=1800
MAX_RETRIES=3
CC_MODEL=claude-opus-4-6

# === Backup ===
BACKUP_INTERVAL_HOURS=1
MAX_BACKUPS=48

# === Web Push (VAPID) ===
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:agenthive@example.com

# === Telegram Bot (optional — for push notifications) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Security ===
# Comma-separated allowed CORS origins (default: * allows all)
CORS_ORIGINS=*
# Set to 1 to disable login authentication (dev only)
# DISABLE_AUTH=1

# === Server Ports ===
PORT=8080
FRONTEND_PORT=3000
