# AgentHive Environment Variables
# Copy to .env and fill in actual values

# === Host Paths (REQUIRED — must be absolute paths) ===
# Projects directory — where all project code lives on the host
HOST_PROJECTS_DIR=/home/YOUR_USERNAME/cc-projects
# Claude config directory — for session symlinks
HOST_CLAUDE_DIR=/home/YOUR_USERNAME/.claude

# === Auth ===
# Run `claude setup-token` on host to generate a 1-year OAuth token, then paste below.
# Uses your Claude Max/Pro subscription (no separate API billing).
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-YOUR_TOKEN_HERE
HOST_USER_UID=1000

# === Optional (needed for voice input) ===
OPENAI_API_KEY=sk-xxx

# === Worker Config ===
MAX_CONCURRENT_WORKERS=5
MAX_IDLE_AGENTS=20
WORKER_CPU_LIMIT=2
WORKER_MEM_LIMIT=4g
TASK_TIMEOUT_SECONDS=600
MAX_RETRIES=3
CC_MODEL=claude-sonnet-4-5-20250514

# === Plan Mode ===
# AUTO_APPROVE_TIMEOUT=300  # Uncomment to enable auto-approve (seconds)

# === Backup ===
BACKUP_INTERVAL_HOURS=1
MAX_BACKUPS=48

# === Server Ports ===
PORT=8080
FRONTEND_PORT=3000
